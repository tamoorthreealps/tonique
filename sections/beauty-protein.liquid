{{ 'css--beauty-protein.css' | asset_url | stylesheet_tag }}

<section class="bp-section" id="BeautyProtein-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="bp-inner--container">
    {%- comment -%} ── Heading ── {%- endcomment -%}
    <div class="bp-intro">
      {%- if section.settings.heading != blank -%}
        <div class="bp-intro__heading">
          {{ section.settings.heading }}
        </div>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="bp-intro__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Table ── {%- endcomment -%}
    <div class="bp-table" id="bp-table-{{ section.id }}">
      {%- comment -%} Header row ── {%- endcomment -%}
      <div class="bp-row bp-row--header">
        {%- comment -%} Empty label cell ── {%- endcomment -%}
        <div class="bp-cell bp-cell--label bp-cell--blank"></div>

        {%- comment -%} TONIQUE header ── {%- endcomment -%}
        <div class="bp-cell bp-cell--tonique bp-cell--header">
          <div class="bp-col-hd">
            {%- if section.settings.tonique_icon != blank -%}
              <div class="bp-col-hd__circle bp-col-hd__circle--tonique">
                {{-
                  section.settings.tonique_icon
                  | image_url: width: 160
                  | image_tag: loading: 'lazy', alt: section.settings.tonique_label, class: 'bp-col-hd__img'
                -}}
              </div>
            {%- else -%}
              <div
                class="bp-col-hd__circle bp-col-hd__circle--tonique bp-col-hd__circle--empty"
                aria-hidden="true"
              ></div>
            {%- endif -%}
            {%- if section.settings.tonique_table_logo != blank -%}
              <div class="bp-col-tonique_logo">
                {{-
                  section.settings.tonique_table_logo
                  | image_url: width: 132
                  | image_tag: loading: 'lazy', alt: section.settings.tonique_label, class: 'bp-col-hd__img'
                -}}
              </div>
            {%- else -%}
              <span class="bp-col-hd__name bp-col-hd__name--tonique">{{ section.settings.tonique_label }}</span>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Competitor headers ── {%- endcomment -%}
        {%- for i in (1..3) -%}
          {%- assign cn_key = 'comp' | append: i | append: '_name' -%}
          {%- assign ci_key = 'comp' | append: i | append: '_icon' -%}
          {%- assign cn = section.settings[cn_key] -%}
          {%- assign ci = section.settings[ci_key] -%}
          <div class="bp-cell bp-cell--comp bp-cell--header" data-bp-comp="{{ i }}">
            <div class="bp-col-hd">
              <div class="bp-col-hd__circle">
                {%- if ci != blank -%}
                  {{- ci | image_url: width: 160 | image_tag: loading: 'lazy', alt: cn, class: 'bp-col-hd__img' -}}
                {%- endif -%}
              </div>
              <span class="bp-col-hd__name">{{ cn }}</span>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Data rows ── {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="bp-row" {{ block.shopify_attributes }}>
          <div class="bp-cell bp-cell--label">
            <span class="bp-label">{{ block.settings.row_label }}</span>
          </div>

          {%- comment -%} Tonique cell ── {%- endcomment -%}
          <div class="bp-cell bp-cell--tonique">
            {%- assign tv = block.settings.tonique_value -%}
            {%- if tv == 'check' -%}
              <span class="bp-tilde bp-tilde--gold" aria-label="Yes">
                <svg width="40" height="12" viewBox="0 0 40 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 5.75C0.594116 5.30252 1.23976 4.94351 1.89485 4.6312C7.98763 1.7851 13.6226 4.3471 18.5687 7.79974C18.5687 7.79974 18.5687 7.79974 18.5687 7.79974C23.9971 12.0596 33.9034 13.4299 38.6798 7.62529C39.1985 7.04034 39.6581 6.41609 40 5.75C39.4059 6.19748 38.7602 6.55649 38.1052 6.8688C32.0124 9.7149 26.3774 7.1529 21.4313 3.70026C21.4313 3.70026 21.4313 3.70026 21.4313 3.70026C16.0029 -0.559606 6.09657 -1.92987 1.32019 3.87471C0.801502 4.45966 0.341909 5.08391 0 5.75Z" fill="#A88958"/>
                </svg>
              </span>
            {%- elsif tv != blank -%}
              <span class="bp-value bp-value--tonique">{{ tv }}</span>
            {%- else -%}
              <span class="bp-dash" aria-hidden="true">—</span>
            {%- endif -%}
          </div>

          {%- comment -%} Competitor cells ── {%- endcomment -%}
          {%- for i in (1..3) -%}
            {%- assign cv_key = 'comp' | append: i | append: '_value' -%}
            {%- assign cv = block.settings[cv_key] -%}
            <div class="bp-cell bp-cell--comp" data-bp-comp="{{ i }}">
              {%- if cv == 'cross' -%}
                <span class="bp-tilde bp-tilde--grey" aria-label="No">
                  <svg width="40" height="12" viewBox="0 0 40 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0 5.75C0.594116 5.30252 1.23976 4.94351 1.89485 4.6312C7.98763 1.7851 13.6226 4.3471 18.5687 7.79974C18.5687 7.79974 18.5687 7.79974 18.5687 7.79974C23.9971 12.0596 33.9034 13.4299 38.6798 7.62529C39.1985 7.04034 39.6581 6.41609 40 5.75C39.4059 6.19748 38.7602 6.55649 38.1052 6.8688C32.0124 9.7149 26.3774 7.1529 21.4313 3.70026C21.4313 3.70026 21.4313 3.70026 21.4313 3.70026C16.0029 -0.559607 6.09658 -1.92987 1.32019 3.87471C0.801502 4.45966 0.341909 5.08391 0 5.75Z" fill="#433723" fill-opacity="0.15"/>
                  </svg>
                </span>
              {%- elsif cv == 'check' -%}
                <span class="bp-tilde bp-tilde--gold" aria-label="Yes">
                  <svg width="40" height="12" viewBox="0 0 40 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0 5.75C0.594116 5.30252 1.23976 4.94351 1.89485 4.6312C7.98763 1.7851 13.6226 4.3471 18.5687 7.79974C18.5687 7.79974 18.5687 7.79974 18.5687 7.79974C23.9971 12.0596 33.9034 13.4299 38.6798 7.62529C39.1985 7.04034 39.6581 6.41609 40 5.75C39.4059 6.19748 38.7602 6.55649 38.1052 6.8688C32.0124 9.7149 26.3774 7.1529 21.4313 3.70026C21.4313 3.70026 21.4313 3.70026 21.4313 3.70026C16.0029 -0.559606 6.09657 -1.92987 1.32019 3.87471C0.801502 4.45966 0.341909 5.08391 0 5.75Z" fill="#A88958"/>
                  </svg>
                </span>
              {%- elsif cv != blank -%}
                <span class="bp-value">{{ cv }}</span>
              {%- else -%}
                <span class="bp-dash" aria-hidden="true">—</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} ── Mobile switcher ── {%- endcomment -%}
    <div class="bp-switcher" id="bp-switcher-{{ section.id }}">
      <div class="bp-switcher__segs" id="bp-segs-{{ section.id }}" role="tablist" aria-label="Switch competitor">
        {%- for i in (1..3) -%}
          {%- assign cn_key = 'comp' | append: i | append: '_name' -%}
          <button
            class="bp-switcher__seg{% if forloop.first %} is-active{% endif %}"
            data-bp-seg="{{ i }}"
            data-bp-name="{{ section.settings[cn_key] }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Show {{ section.settings[cn_key] }}"
            type="button"
          ></button>
        {%- endfor -%}
      </div>
      <p class="bp-switcher__label" id="bp-label-{{ section.id }}">
        {%- assign first_cn_key = 'comp1_name' -%}
        {{ section.settings[first_cn_key] }} · 1 OF 3
      </p>
    </div>

    {%- comment -%} ── Footnote ── {%- endcomment -%}
    {%- if section.settings.footnote != blank -%}
      <p class="bp-footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var sid = '{{ section.id }}';
    var compNames = [
      {{ section.settings.comp1_name | json }},
      {{ section.settings.comp2_name | json }},
      {{ section.settings.comp3_name | json }}
    ];
    var total = compNames.length;
    var active = 1;

    function activateComp(num) {
      if (num === active) return;
      active = num;

      // Toggle all [data-bp-comp] cells (includes header + data rows)
      document.querySelectorAll('#bp-table-' + sid + ' [data-bp-comp]').forEach(function (el) {
        el.classList.toggle('is-active-comp', parseInt(el.dataset.bpComp, 10) === num);
      });

      // Segment tabs
      document.querySelectorAll('#bp-segs-' + sid + ' .bp-switcher__seg').forEach(function (s) {
        var isA = parseInt(s.dataset.bpSeg, 10) === num;
        s.classList.toggle('is-active', isA);
        s.setAttribute('aria-selected', isA ? 'true' : 'false');
      });

      // Counter label
      var lbl = document.getElementById('bp-label-' + sid);
      if (lbl) lbl.textContent = compNames[num - 1] + ' · ' + num + ' OF ' + total;
    }

    // Init — mark first competitor active
    document.querySelectorAll('#bp-table-' + sid + ' [data-bp-comp]').forEach(function (el) {
      el.classList.toggle('is-active-comp', parseInt(el.dataset.bpComp, 10) === 1);
    });

    // Segment clicks
    document.querySelectorAll('#bp-segs-' + sid + ' .bp-switcher__seg').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activateComp(parseInt(this.dataset.bpSeg, 10));
      });
    });
  })();


{% comment %} calculate--table--highlight--col {% endcomment %}
 function updateToniqueHeight() {
  const table = document.querySelector('.bp-table');
  const tonique = document.querySelector('.bp-row:first-child .bp-cell--tonique');

  if (!table || !tonique) return;

  const tableHeight = table.offsetHeight;

  tonique.style.setProperty('--table-height', `${tableHeight}px`);
}

updateToniqueHeight();

window.addEventListener('resize', updateToniqueHeight);
</script>

