            "description": "Natural zero-calorie sweetener — no sucralose, no aftertaste."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Biotin",
            "amount": "300mcg",
            "badge_label": "BIOTIN",
            "description": "Supports healthy hair, skin, and nail growth from within."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Passionfruit",
            "amount": "<1%",
