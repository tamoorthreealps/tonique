{{ 'css--text-scroller.css' | asset_url | stylesheet_tag }}

<div
  class="
    ts-section {% if section.settings.enable_top_border %} ts-section--top-border{% endif %}
    {% if section.settings.enable_bottom_border %} ts-section--bottom-border{% endif %}
  "
  id="TextScroller-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="ts-track-wrap" aria-hidden="true">
    <div class="ts-track" id="ts-track-{{ section.id }}">
      {%- comment -%} First set {%- endcomment -%}
      {%- for block in section.blocks -%}
        <span class="ts-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {%- endfor -%}
      {%- comment -%} Duplicate — seamless infinite loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        <span class="ts-item">{{ block.settings.text }}</span>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Text Scroller",
  "class": "section-text-scroller",
    "settings": [
    {
      "type": "checkbox",
      "id": "enable_top_border",
      "label": "Enable top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_bottom_border",
      "label": "Enable bottom border",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Scroll item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "No artificial sweeteners"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text Scroller",
      "blocks": [
        { "type": "item", "settings": { "text": "No sucralose" } },
        { "type": "item", "settings": { "text": "No sodium benzoate" } },
        { "type": "item", "settings": { "text": "No artificial sweeteners" } },
        { "type": "item", "settings": { "text": "No sucralose" } },
        { "type": "item", "settings": { "text": "No sodium benzoate" } },
        { "type": "item", "settings": { "text": "No artificial sweeteners" } }
      ]
    }
  ]
}
{% endschema %}
