{{ 'component--custom--faqs.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Custom FAQs",
  "settings": [
    {
      "type": "text",
      "id": "mobile_title",
      "label": "Mobile Title",
      "default": "FAQs"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "FAQ Category",
      "settings": [
        {
          "type": "text",
          "id": "category_title",
          "label": "Category Title",
          "default": "THE PRODUCT"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "faq_category",
          "label": "Category Handle",
          "info": "Example: the-product"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How often should I drink it?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom FAQs"
    }
  ]
}
{% endschema %}

<section class="custom-faqs" id="customFaqs">
  <div class="custom-faqs__wrapper_container">
    <div class="custom-faqs__wrapper">
      <div class="custom-faqs__mobile-top">
        <h2 class="custom-faqs__sidebar_heading">{{ section.settings.mobile_title }}</h2>
        <p class="custom-faqs__sidebar_content">
          Everything you might want to know about Tonique; the product, the ingredients, and how it fits into your day.
        </p>
        <div class="custom-faqs__mobile-dropdown">
          <select id="faqCategorySelect">
            {% for block in section.blocks %}
              {% if block.type == 'category' %}
                <option value="{{ block.settings.category_title | handle }}">
                  {{ block.settings.category_title }}
                </option>
              {% endif %}
            {% endfor %}
          </select>
        </div>
      </div>

      <div class="custom-faqs__sidebar">
        <div class="custom-faqs__sidebar_top">
          <h1 class="custom-faqs__sidebar_heading">FAQs</h1>
          <p class="custom-faqs__sidebar_content">
            Everything you might want to know about Tonique; the product, the ingredients, and how it fits into your
            day.
          </p>
        </div>
        <ul>
          {% for block in section.blocks %}
            {% if block.type == 'category' %}
              <li
                class="{% if forloop.first %}active{% endif %}"
                data-target="{{ block.settings.category_title | handle }}"
              >
                <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9.85098 0L8.88889 0.935593L13.4275 5.34915H0V6.65085H13.4275L8.88889 11.0644L9.85098 12L15.5399 6.4678L16 6L15.5399 5.5322L9.85098 0Z" fill="#A88958"/>
                </svg>
                <span>{{ block.settings.category_title }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
        <p class="custom-faqs__sidebar_content_footer">
          Email us at <a href="mailto:hello@tonique.com" class="">hello@tonique.com</a>. We read everything and reply
          within one business day.
        </p>
      </div>

      <div class="custom-faqs__content">
        {% for block in section.blocks %}
          {% if block.type == 'category' %}
            {% assign category_handle = block.settings.category_title | handle %}

            <div
              class="faq-category {% if forloop.first %}active-mobile{% endif %}"
              id="{{ category_handle }}"
            >
              <h2>{{ block.settings.category_title }}</h2>

              {% for faq in section.blocks %}
                {% if faq.type == 'faq' %}
                  {% assign faq_handle = faq.settings.faq_category | handle %}

                  {% if faq_handle == category_handle %}
                    <div class="faq-item {% if forloop.first %}active{% endif %}">
                      <div class="faq-question">
                        <span>{{ faq.settings.question }}</span>
                        <span>
                          <svg
                            class="faq--plus--icon"
                            width="12"
                            height="12"
                            viewBox="0 0 12 12"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M5.40088 0V5.38847H0V6.88657H5.40088V12H6.90015V6.88657H12V5.38847H6.90015V0H5.40088Z" fill="#433723"/>
                          </svg>

                          <svg
                            class="faq--minus--icon"
                            width="12"
                            height="12"
                            viewBox="0 0 12 12"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M5.40088 5.38867L0 5.38944V6.88754H5.40088H6.90015H12V5.38944H6.90015L5.40088 5.38867Z" fill="#977B4F"/>
                          </svg>
                        </span>
                      </div>

                      <div class="faq-answer">
                        {{ faq.settings.answer }}
                      </div>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('#customFaqs');

    if (!section) return;

    const sidebarItems = section.querySelectorAll('.custom-faqs__sidebar li');
    const categories = section.querySelectorAll('.faq-category');

    sidebarItems.forEach((item) => {
      item.addEventListener('click', function () {
        const target = this.dataset.target;
        const targetEl = document.getElementById(target);

        if (targetEl) {
          window.scrollTo({
            top: targetEl.offsetTop - 100,
            behavior: 'smooth',
          });
        }
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');

            sidebarItems.forEach((item) => {
              item.classList.remove('active');

              if (item.dataset.target === id) {
                item.classList.add('active');
              }
            });
          }
        });
      },
      {
        threshold: 0.3,
      }
    );

    categories.forEach((section) => {
      observer.observe(section);
    });

    const faqItems = section.querySelectorAll('.faq-item');

    faqItems.forEach((item) => {
      const question = item.querySelector('.faq-question');

      question.addEventListener('click', function () {
        const isActive = item.classList.contains('active');

        faqItems.forEach((i) => {
          i.classList.remove('active');
        });

        if (!isActive) {
          item.classList.add('active');
        }
      });
    });

    const select = document.getElementById('faqCategorySelect');

    function mobileCategoryShow(value) {
      categories.forEach((cat) => {
        cat.classList.remove('active-mobile');
      });

      const target = section.querySelector('#' + value);

      if (target) {
        target.classList.add('active-mobile');
      }
    }

    if (window.innerWidth < 767 && select) {
      mobileCategoryShow(select.value);
    }

    if (select) {
      select.addEventListener('change', function () {
        mobileCategoryShow(this.value);
      });
    }
  });
</script>
