{% liquid
  assign sid = section.id
%}

<section
  class="hp-hero"
  id="Hero-{{ sid }}"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;

    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
  {{ section.shopify_attributes }}
>

  <div class="hp-hero__inner">

    <div class="hp-hero__content">

      {% if section.settings.heading != blank %}
        <h1 class="hp-hero__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="hp-hero__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="hp-hero__button"
        >
          {{ section.settings.button_text }}
        </a>
      {% endif %}

    </div>

    <div class="hp-hero__visual">

      {% if section.settings.wave_image != blank %}
        <img
          class="hp-hero__waves"
          src="{{ section.settings.wave_image | image_url: width: 2000 }}"
          alt=""
          loading="lazy"
        >
      {% endif %}

      {% if section.settings.product_image != blank %}
        <img
          class="hp-hero__product"
          src="{{ section.settings.product_image | image_url: width: 1200 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}

      {% for block in section.blocks %}

        <div
          class="hp-hero__badge"
          {{ block.shopify_attributes }}
          style="
            --badge-top-d: {{ block.settings.top_desktop }}%;
            --badge-left-d: {{ block.settings.left_desktop }}%;

            --badge-top-m: {{ block.settings.top_mobile }}%;
            --badge-left-m: {{ block.settings.left_mobile }}%;

            --badge-size-d: {{ block.settings.size_desktop }}px;
            --badge-size-m: {{ block.settings.size_mobile }}px;
          "
        >

          {% if block.settings.big_text != blank %}
            <div class="hp-hero__badge-big">
              {{ block.settings.big_text }}
            </div>
          {% endif %}

          {% if block.settings.small_text != blank %}
            <div class="hp-hero__badge-small">
              {{ block.settings.small_text }}
            </div>
          {% endif %}

        </div>

      {% endfor %}

    </div>

  </div>

</section>

<style>

.hp-hero {
  overflow: hidden;
}

.hp-hero__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 80px;

  padding-top: var(--pt-mobile);
  padding-bottom: var(--pb-mobile);

  position: relative;
}

.hp-hero__content {
  width: 100%;
  max-width: 420px;
  position: relative;
  z-index: 3;
}

.hp-hero__heading {
  margin: 0 0 20px;

  color: #a8844b;

  font-size: 34px;
  line-height: 1.05;
  letter-spacing: -.02em;
  font-weight: 400;
  text-transform: uppercase;
}

.hp-hero__text {
  max-width: 360px;

  color: #4f4538;

  font-size: 14px;
  line-height: 1.7;
}

.hp-hero__text p {
  margin: 0;
}

.hp-hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  min-width: 146px;
  height: 48px;

  margin-top: 28px;
  padding: 0 24px;

  background: #a8844b;
  color: #fff;

  text-decoration: none;
  text-transform: uppercase;

  font-size: 12px;
  font-weight: 600;
  letter-spacing: .08em;

  transition: .3s ease;
}

.hp-hero__button:hover {
  opacity: .85;
}

.hp-hero__visual {
  width: 100%;
  max-width: 620px;

  position: relative;

  display: flex;
  align-items: center;
  justify-content: center;
}

.hp-hero__waves {
  position: absolute;

  width: 120%;
  max-width: none;

  left: 50%;
  top: 50%;

  transform: translate(-50%, -50%);

  z-index: 1;
  pointer-events: none;
}

.hp-hero__product {
  width: 100%;
  max-width: 330px;

  display: block;
  position: relative;
  z-index: 2;
}

.hp-hero__badge {
  position: absolute;

  top: var(--badge-top-m);
  left: var(--badge-left-m);

  width: var(--badge-size-m);
  height: var(--badge-size-m);

  border-radius: 50%;
  border: 1px solid #b38b51;

  background: #faf8f3;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  text-align: center;

  z-index: 3;
}

.hp-hero__badge-big {
  color: #b38b51;

  font-size: 15px;
  line-height: 1;
  font-weight: 500;
}

.hp-hero__badge-small {
  margin-top: 5px;

  color: #b38b51;

  font-size: 9px;
  line-height: 1.1;
  text-transform: uppercase;
}

@media screen and (min-width: 768px) {

  .hp-hero__inner {
    padding-top: var(--pt-desktop);
    padding-bottom: var(--pb-desktop);
  }

  .hp-hero__heading {
    font-size: 58px;
    line-height: .98;
  }

  .hp-hero__text {
    font-size: 18px;
  }

  .hp-hero__button {
    margin-top: 36px;
  }

  .hp-hero__badge {
    top: var(--badge-top-d);
    left: var(--badge-left-d);

    width: var(--badge-size-d);
    height: var(--badge-size-d);
  }

  .hp-hero__badge-big {
    font-size: 24px;
  }

  .hp-hero__badge-small {
    font-size: 12px;
  }

}

@media screen and (max-width: 767px) {

  .hp-hero__inner {
    flex-direction: column;
    gap: 42px;
  }

  .hp-hero__content {
    max-width: 100%;
    text-align: center;
  }

  .hp-hero__text {
    margin: 0 auto;
  }

  .hp-hero__visual {
    max-width: 100%;
  }

  .hp-hero__product {
    max-width: 200px;
  }

}

</style>

{% schema %}
{
  "name": "Homepage Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "image_picker",
      "id": "wave_image",
      "label": "Wave image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BEAUTY + PROTEIN IN ONE CLEAN POUCH"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },

    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 120
    },

    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],

  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "big_text",
          "label": "Big text",
          "default": "15g"
        },
        {
          "type": "text",
          "id": "small_text",
          "label": "Small text",
          "default": "Protein"
        },

        {
          "type": "header",
          "content": "Desktop"
        },

        {
          "type": "range",
          "id": "top_desktop",
          "label": "Top desktop",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "%",
          "default": 28
        },
        {
          "type": "range",
          "id": "left_desktop",
          "label": "Left desktop",
          "min": -20,
          "max": 120,
          "step": 2,
          "unit": "%",
          "default": 22
        },
        {
          "type": "range",
          "id": "size_desktop",
          "label": "Size desktop",
          "min": 40,
          "max": 220,
          "step": 2,
          "unit": "px",
          "default": 120
        },

        {
          "type": "header",
          "content": "Mobile"
        },

        {
          "type": "range",
          "id": "top_mobile",
          "label": "Top mobile",
          "min": -20,
          "max": 120,
          "step": 2,
          "unit": "%",
          "default": 28
        },
        {
          "type": "range",
          "id": "left_mobile",
          "label": "Left mobile",
          "min": -20,
          "max": 120,
          "step": 2,
          "unit": "%",
          "default": 10
        },
        {
          "type": "range",
          "id": "size_mobile",
          "label": "Size mobile",
          "min": 40,
          "max": 180,
          "step": 2,
          "unit": "px",
          "default": 90
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Homepage Hero",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "big_text": "15g",
            "small_text": "Protein"
          }
        },
        {
          "type": "badge",
          "settings": {
            "big_text": "70",
            "small_text": "Calories"
          }
        },
        {
          "type": "badge",
          "settings": {
            "big_text": "0g",
            "small_text": "Sugar"
          }
        },
        {
          "type": "badge",
          "settings": {
            "big_text": "1oz",
            "small_text": "Pouch"
          }
        }
      ]
    }
  ]
}
{% endschema %}