{{ 'css--whats-inside.css' | asset_url | stylesheet_tag }}

<section class="wi-section" id="WhatsInside-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="wi-inner--container">
    {%- comment -%} ── Mobile-only heading ── {%- endcomment -%}
    <div class="wi-mobile-heading">
      {%- if section.settings.heading != blank -%}
        <h2 class="wi-mobile-heading__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="wi-mobile-heading__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Desktop: 2-col split ── {%- endcomment -%}
    <div class="wi-desktop-inner">
      {%- comment -%} Left: heading + ingredient list ── {%- endcomment -%}
      <div class="wi-left__top">
        <div class="wi-left">
          <div class="wi-heading">
            {%- if section.settings.heading != blank -%}
              <h2 class="wi-heading__title">{{ section.settings.heading }}</h2>
            {%- endif -%}
            {%- if section.settings.subtext != blank -%}
              <p class="wi-heading__sub">{{ section.settings.subtext }}</p>
            {%- endif -%}
          </div>

          <div class="wi-list" id="wi-list-{{ section.id }}">
            {%- for block in section.blocks -%}
              <button
                class="wi-row{% if forloop.first %} is-active{% endif %}"
                data-wi-row="{{ forloop.index }}"
                data-wi-section="{{ section.id }}"
                type="button"
                aria-label="{{ block.settings.ingredient_name }}"
                {{ block.shopify_attributes }}
              >
                <div class="wi-list-hold">
                  <span class="wi-row__dot" aria-hidden="true"></span>
                  <span class="wi-row__name">{{ block.settings.ingredient_name }}</span>
                  <span class="wi-row__amount">{{ block.settings.amount }}</span>
                </div>
              </button>
            {%- endfor -%}
          </div>
        </div>
      </div>

      {%- comment -%} Right: detail cards ── {%- endcomment -%}
      <div class="wi-right">
        <div class="wi-panel" id="wi-panel-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div
              class="wi-card{% if forloop.first %} is-active{% endif %}"
              data-wi-card="{{ forloop.index }}"
              aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image != blank or block.settings.badge_label != blank -%}
                <div class="wi-card__image-wrap">
                  {{-
                    block.settings.image
                    | image_url: width: 640
                    | image_tag:
                      loading: 'lazy',
                      alt: block.settings.ingredient_name,
                      class: 'wi-card__image',
                      widths: '320, 640',
                      sizes: '(max-width: 767px) 156px, 320px'
                  -}}
                  {%- if block.settings.badge_label != blank -%}
                    <span class="wi-card__badge">{{ block.settings.badge_label }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="wi-card__body">
                <h3 class="wi-card__name">{{ block.settings.ingredient_name }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="wi-card__desc">{{ block.settings.description }}</p>
                {%- endif -%}
                <div class="wi-card__divider" aria-hidden="true"></div>
                <div class="wi-card__amount-row">
                  <span class="wi-card__amount">{{ block.settings.amount }}</span>
                  <span class="wi-card__per">PER POUCH</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- comment -%} ── Mobile: horizontal scroll cards ── {%- endcomment -%}
    <div class="wi-mobile-scroll splide" id="wi-mobile-{{ section.id }}">
      <div class="splide__track">
        <div class="splide__list">
          {%- for block in section.blocks -%}
            <div class="wi-scroll-card splide__slide" {{ block.shopify_attributes }}>
              <div class="wi-scroll-card__top">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 344
                    | image_tag: loading: 'lazy', alt: block.settings.ingredient_name, class: 'wi-scroll-card__image'
                  }}
                {%- endif -%}

                {%- if block.settings.badge_label != blank -%}
                  <span class="wi-scroll-card__badge">
                    {{ block.settings.badge_label }}
                  </span>
                {%- endif -%}
              </div>

              <div class="wi-scroll-card__body">
                <p class="wi-scroll-card__name">
                  {{ block.settings.ingredient_name }}
                </p>

                <div class="wi-scroll-card__divider"></div>

                <div class="wi-scroll-card__amount-row">
                  <span class="wi-scroll-card__amount">
                    {{ block.settings.amount }}
                  </span>

                  <span class="wi-scroll-card__per"> PER POUCH </span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sid = '{{ section.id }}';

    function activate(num) {
      document.querySelectorAll('#wi-list-' + sid + ' .wi-row').forEach(function (r) {
        r.classList.toggle('is-active', parseInt(r.dataset.wiRow, 10) === num);
      });
      document.querySelectorAll('#wi-panel-' + sid + ' .wi-card').forEach(function (c) {
        var isActive = parseInt(c.dataset.wiCard, 10) === num;
        c.classList.toggle('is-active', isActive);
        c.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    }

    document.querySelectorAll('#wi-list-' + sid + ' .wi-row').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activate(parseInt(this.dataset.wiRow, 10));
      });
    });
  })();


document.addEventListener('DOMContentLoaded', function () {
  new Splide('#wi-mobile-{{ section.id }}', {
    type: 'loop',
    perPage: 1.2,
    gap: '16px',
    pagination: false,
    arrows: false,
    drag: true,
    breakpoints: {
      768: {
        perPage: 1.1
      }
    }
  }).mount();
});
</script>

{% schema %}
{
  "name": "What's Inside",
  "class": "section-whats-inside",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT'S INSIDE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every ingredient, every amount — nothing hidden."
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "ingredient_name",
          "label": "Ingredient name",
          "default": "Hydrolyzed Collagen Peptides"
        },
        {
          "type": "text",
          "id": "amount",
          "label": "Amount",
          "default": "8g"
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge label",
          "default": "COLLAGEN"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Type I & III collagen peptides to support skin elasticity, joint comfort, and lean body composition."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What's Inside",
