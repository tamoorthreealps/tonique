{{ 'css--multisteps-popup.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_popup -%}
  <div
    id="msp-overlay-{{ section.id }}"
    class="msp-overlay"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="{{ section.settings.step1_heading | escape }}"
  >
    <div class="msp-popup" role="document">
      {%- comment -%} ── Close button ── {%- endcomment -%}
      <button
        class="msp-close"
        id="msp-close-{{ section.id }}"
        type="button"
        aria-label="Close popup"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M2 2L14 14M14 2L2 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>

      {%- comment -%} ── Pouch neck (decorative top silhouette) ── {%- endcomment -%}
      <div class="msp-neck" aria-hidden="true"></div>

      {%- comment -%} ── Card body ── {%- endcomment -%}
      <div class="msp-card">
        {%- comment -%} ════ STEP 1 — EMAIL ════ {%- endcomment -%}
        <div class="msp-step" data-msp-step="1">
          {%- if section.settings.step1_heading != blank -%}
            <h2 class="msp-heading">{{ section.settings.step1_heading }}</h2>
          {%- endif -%}

          {%- if section.settings.step1_subheading != blank -%}
            <p class="msp-subheading">{{ section.settings.step1_subheading }}</p>
          {%- endif -%}

          {%- if section.settings.step1_body != blank -%}
            <p class="msp-body">{{ section.settings.step1_body }}</p>
          {%- endif -%}

          {%- comment -%} Klaviyo email form embed — paste embed div here {%- endcomment -%}
          {%- if section.settings.step1_klaviyo_html != blank -%}
            <div class="msp-klaviyo-form" data-msp-form="1">
              {{ section.settings.step1_klaviyo_html }}
            </div>
          {%- else -%}
            {%- comment -%} Placeholder shown in customizer when no embed pasted {%- endcomment -%}
            <div class="msp-klaviyo-form msp-klaviyo-form--placeholder">
              <input type="email" placeholder="Email address" disabled>
              <button type="button">UNLOCK {{ section.settings.step1_heading | escape }}</button>
            </div>
          {%- endif -%}

          {%- if section.settings.step1_disclaimer != blank -%}
            <p class="msp-disclaimer">{{ section.settings.step1_disclaimer }}</p>
          {%- endif -%}

          {%- if section.settings.step1_skip_label != blank -%}
            <button
              class="msp-skip"
              type="button"
              data-msp-action="close"
            >
              {{ section.settings.step1_skip_label }}
            </button>
          {%- endif -%}
        </div>

        {%- comment -%} ════ STEP 2 — PHONE ════ {%- endcomment -%}
        <div class="msp-step" data-msp-step="2" hidden>
          {%- if section.settings.step2_heading != blank -%}
            <h2 class="msp-heading">{{ section.settings.step2_heading }}</h2>
          {%- endif -%}

          {%- if section.settings.step2_subheading != blank -%}
            <p class="msp-subheading msp-subheading--gold">{{ section.settings.step2_subheading }}</p>
          {%- endif -%}

          {%- if section.settings.step2_body != blank -%}
            <p class="msp-body">{{ section.settings.step2_body }}</p>
          {%- endif -%}

          {%- comment -%} Klaviyo SMS form embed {%- endcomment -%}
          {%- if section.settings.step2_klaviyo_html != blank -%}
            <div class="msp-klaviyo-form" data-msp-form="2">
              {{ section.settings.step2_klaviyo_html }}
            </div>
          {%- else -%}
            <div class="msp-klaviyo-form msp-klaviyo-form--placeholder">
              <input type="tel" placeholder="Phone number" disabled>
              <button type="button">YES, I WANT IT</button>
            </div>
          {%- endif -%}

          {%- if section.settings.step2_disclaimer != blank -%}
            <p class="msp-disclaimer">{{ section.settings.step2_disclaimer }}</p>
          {%- endif -%}

          {%- if section.settings.step2_skip_label != blank -%}
            <button
              class="msp-skip"
              type="button"
              data-msp-action="advance"
            >
              {{ section.settings.step2_skip_label }}
            </button>
          {%- endif -%}
        </div>

        {%- comment -%} ════ STEP 3 — SUCCESS ════ {%- endcomment -%}
        <div class="msp-step" data-msp-step="3" hidden>
          {%- if section.settings.step3_heading != blank -%}
            <h2 class="msp-heading">{{ section.settings.step3_heading }}</h2>
          {%- endif -%}

          {%- if section.settings.step3_subheading != blank -%}
            <p class="msp-subheading msp-subheading--gold">{{ section.settings.step3_subheading }}</p>
          {%- endif -%}

          {%- if section.settings.step3_body != blank -%}
            <p class="msp-body">{{ section.settings.step3_body }}</p>
          {%- endif -%}

          {%- if section.settings.step3_cta_label != blank -%}
            <a
              href="{{ section.settings.step3_cta_link | default: '/collections/all' }}"
              class="msp-btn"
              id="msp-cta3-{{ section.id }}"
            >
              {{- section.settings.step3_cta_label -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} ── Logo ── {%- endcomment -%}
        {%- if section.settings.logo_text != blank -%}
          <div class="msp-logo" aria-hidden="true">{{ section.settings.logo_text }}</div>
        {%- endif -%}
      </div>
      {%- comment -%} /.msp-card {%- endcomment -%}
    </div>
    {%- comment -%} /.msp-popup {%- endcomment -%}
  </div>
  {%- comment -%} /.msp-overlay {%- endcomment -%}

  <script>
    (function () {
      'use strict';

      var sid          = '{{ section.id }}';
      var COOKIE_NAME  = {{ section.settings.cookie_name | default: 'tonique_popup' | json }};
      var COOKIE_DAYS  = {{ section.settings.cookie_expiry_days | default: 30 }};
      var DELAY_MS     = {{ section.settings.trigger_delay | default: 3 }} * 1000;
      var SCROLL_PCT   = {{ section.settings.trigger_scroll | default: 50 }};

      /* ── Elements ───────────────────────────── */
      var overlay  = document.getElementById('msp-overlay-' + sid);
      var closeBtn = document.getElementById('msp-close-' + sid);
      if (!overlay) return;

      /* ── Cookie helpers ─────────────────────── */
      function getCookie(name) {
        var m = document.cookie.match('(?:^|;)\\s*' + name + '=([^;]*)');
        return m ? decodeURIComponent(m[1]) : null;
      }

      function setCookie(name, value, days) {
        var exp = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) +
          '; expires=' + exp + '; path=/; SameSite=Lax';
      }

      /* ── Bail if already seen ───────────────── */
      if (getCookie(COOKIE_NAME)) return;

      /* ── State ──────────────────────────────── */
      var triggered    = false;
      var currentStep  = 1;
      var delayTimer   = null;

      /* ── Helpers: show / hide ───────────────── */
      function showPopup() {
        if (triggered) return;
        triggered = true;
        clearTimeout(delayTimer);
        window.removeEventListener('scroll', onScroll, true);
        overlay.removeAttribute('aria-hidden');
        overlay.classList.add('is-visible');
        document.body.classList.add('msp-body-lock');
      }

      function hidePopup() {
        overlay.setAttribute('aria-hidden', 'true');
        overlay.classList.remove('is-visible');
        document.body.classList.remove('msp-body-lock');
      }

      /* ── Step navigation ────────────────────── */
      function goToStep(n) {
        var all = overlay.querySelectorAll('.msp-step');
        all.forEach(function (el) {
          var stepNum = parseInt(el.getAttribute('data-msp-step'), 10);
          if (stepNum === n) {
            el.hidden = false;
            el.removeAttribute('hidden');
          } else {
            el.hidden = true;
          }
        });
        currentStep = n;
      }

      function advanceStep() {
        goToStep(currentStep + 1);
      }

      /* ── Triggers ───────────────────────────── */
      // 1. Delay timer
      delayTimer = setTimeout(showPopup, DELAY_MS);

      // 2. Scroll %
      function onScroll() {
        var docH   = document.documentElement.scrollHeight - window.innerHeight;
        var pct    = docH > 0 ? (window.scrollY / docH) * 100 : 0;
        if (pct >= SCROLL_PCT) showPopup();
      }
      window.addEventListener('scroll', onScroll, { passive: true, capture: true });

      /* ── Close button ───────────────────────── */
      if (closeBtn) {
        closeBtn.addEventListener('click', hidePopup);
      }

      /* ── Click outside to close ─────────────── */
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) hidePopup();
      });

      /* ── Escape key ─────────────────────────── */
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && overlay.classList.contains('is-visible')) {
          hidePopup();
        }
      });

      /* ── Skip / action buttons ──────────────── */
      overlay.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-msp-action]');
        if (!btn) return;
        var action = btn.getAttribute('data-msp-action');
        if (action === 'close') {
          hidePopup();
        } else if (action === 'advance') {
          advanceStep();
        }
      });

      /* ── Step 3 CTA — close popup on click ──── */
      var cta3 = document.getElementById('msp-cta3-' + sid);
      if (cta3) {
        cta3.addEventListener('click', function () {
          hidePopup();
        });
      }

      /* ── Klaviyo form submission events ─────── */
      /*
       * Klaviyo fires a 'klaviyoForms' CustomEvent on the document
       * with e.detail.type === 'submit' or 'stepSubmit' after a
       * form is submitted successfully.
       *
       * Step 1 submit → set suppression cookie + advance to step 2
       * Step 2 submit → advance to step 3
       */
      document.addEventListener('klaviyoForms', function (e) {
        if (!overlay.classList.contains('is-visible')) return;

        var type = e.detail && e.detail.type;
        if (type !== 'submit' && type !== 'stepSubmit') return;

        if (currentStep === 1) {
          /* Email captured — set cookie to suppress future popups */
          setCookie(COOKIE_NAME, '1', COOKIE_DAYS);
          advanceStep();
        } else if (currentStep === 2) {
          advanceStep();
        }
      });

    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Multi-Step Popup",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Popup trigger"
    },
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "range",
      "id": "trigger_delay",
      "label": "Show after (seconds)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 3,
      "info": "Popup shows after this many seconds OR after the scroll threshold below — whichever fires first."
    },
    {
      "type": "range",
      "id": "trigger_scroll",
      "label": "Show after scroll (%)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50,
      "info": "Popup shows when the visitor has scrolled this percentage of the page."
    },
    {
      "type": "header",
      "content": "Cookie settings"
    },
    {
      "type": "range",
      "id": "cookie_expiry_days",
      "label": "Suppress popup for (days)",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 30,
      "info": "After the email is submitted, the popup will not show again for this many days."
    },
    {
      "type": "text",
      "id": "cookie_name",
      "label": "Cookie name",
      "default": "tonique_popup",
      "info": "Internal identifier. Only change if you have multiple popups."
    },
    {
      "type": "header",
      "content": "Step 1 — Email"
    },
    {
      "type": "text",
      "id": "step1_heading",
      "label": "Heading",
      "default": "15% OFF"
    },
    {
      "type": "text",
      "id": "step1_subheading",
      "label": "Subheading",
      "default": "YOUR FIRST ORDER"
    },
    {
      "type": "textarea",
      "id": "step1_body",
      "label": "Body text",
      "default": "15g of clean protein. Beauty nutrients built in. Your daily ritual starts in your inbox."
    },
    {
      "type": "html",
      "id": "step1_klaviyo_html",
      "label": "Klaviyo email form embed code",
      "info": "Paste your Klaviyo email form embed code here (e.g. <div class=\"klaviyo-form-XXXXX\"></div>). Requires Klaviyo JavaScript to be loaded in the theme."
    },
    {
      "type": "textarea",
      "id": "step1_disclaimer",
      "label": "Disclaimer text",
      "default": "By signing up, you agree to receive email marketing. Unsubscribe anytime."
    },
    {
      "type": "text",
      "id": "step1_skip_label",
      "label": "Skip link label",
      "default": "I'll pass for now",
      "info": "Clicking this closes the popup entirely."
    },
    {
      "type": "header",
      "content": "Step 2 — Phone / SMS"
    },
    {
      "type": "text",
      "id": "step2_heading",
      "label": "Heading",
      "default": "MAKE IT 20%"
    },
    {
      "type": "text",
      "id": "step2_subheading",
      "label": "Subheading",
      "default": "GET AN EXTRA 5% OFF"
    },
    {
      "type": "textarea",
      "id": "step2_body",
      "label": "Body text",
      "default": "Add your number for an extra 5% off your first order, plus restock alerts and the occasional drop."
    },
    {
      "type": "html",
      "id": "step2_klaviyo_html",
      "label": "Klaviyo SMS form embed code",
      "info": "Paste your Klaviyo SMS/phone form embed code here."
    },
    {
      "type": "textarea",
      "id": "step2_disclaimer",
      "label": "Disclaimer text",
      "default": "By entering your phone number and submitting this form, you consent to receive marketing text messages (such as promotion codes and cart reminders) from Tonique at the number provided. Consent is not a condition of any purchase. Msg frequency varies. Msg & data rates may apply. Reply HELP for help or STOP to unsubscribe."
    },
    {
      "type": "text",
      "id": "step2_skip_label",
      "label": "Skip link label",
      "default": "Skip and continue",
      "info": "Clicking this advances to the success screen (step 3)."
    },
    {
      "type": "header",
      "content": "Step 3 — Success"
    },
    {
      "type": "text",
      "id": "step3_heading",
      "label": "Heading",
      "default": "YOU'RE IN."
    },
    {
      "type": "text",
      "id": "step3_subheading",
      "label": "Subheading",
      "default": "20% OFF UNLOCKED"
    },
    {
      "type": "textarea",
      "id": "step3_body",
      "label": "Body text",
      "default": "Your code is in your inbox — and we'll text you when the next drop lands."
    },
    {
      "type": "text",
      "id": "step3_cta_label",
      "label": "Button label",
      "default": "START SHOPPING"
    },
    {
      "type": "url",
      "id": "step3_cta_link",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TONIQUE"
    }
  ],
  "presets": [
    {
      "name": "Multi-Step Popup"
    }
  ]
}
{% endschema %}
