<section class="custom-faqs">
  <div class="custom-faqs__wrapper page-width">

    <div class="custom-faqs__mobile-dropdown">
      <select id="faqCategorySelect">
        <option value="product">THE PRODUCT</option>
        <option value="using">USING IT</option>
        <option value="ingredients">INGREDIENTS & DIETARY</option>
        <option value="orders">ORDERS & SHIPPING</option>
      </select>
    </div>

    <div class="custom-faqs__sidebar">
      <ul>
        <li class="active" data-target="product">
          <span>THE PRODUCT</span>
          <svg viewBox="0 0 24 24">
            <path d="M9 6L15 12L9 18" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
        </li>

        <li data-target="using">
          <span>USING IT</span>
          <svg viewBox="0 0 24 24">
            <path d="M9 6L15 12L9 18" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
        </li>

        <li data-target="ingredients">
          <span>INGREDIENTS & DIETARY</span>
          <svg viewBox="0 0 24 24">
            <path d="M9 6L15 12L9 18" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
        </li>

        <li data-target="orders">
          <span>ORDERS & SHIPPING</span>
          <svg viewBox="0 0 24 24">
            <path d="M9 6L15 12L9 18" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
        </li>
      </ul>
    </div>

    <div class="custom-faqs__content">

      <div class="faq-category" id="product">
        <h2>THE PRODUCT</h2>

        <div class="faq-item active">
          <div class="faq-question">
            <span>How often should I drink it?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>
              Collagen alone is missing essential amino acids your body needs.
              We add a targeted Amino Complex to fill the gaps — so every sip
              supports muscle, skin, hair, and joints.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span>What makes the protein complete?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span>How does the subscription work?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
          </div>
        </div>
      </div>

      <div class="faq-category" id="using">
        <h2>USING IT</h2>

        <div class="faq-item">
          <div class="faq-question">
            <span>How do I use a pouch?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Mix with water and enjoy daily.</p>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span>Can I take it with coffee?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Yes absolutely.</p>
          </div>
        </div>
      </div>

      <div class="faq-category" id="ingredients">
        <h2>INGREDIENTS & DIETARY</h2>

        <div class="faq-item">
          <div class="faq-question">
            <span>Is it gluten free?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Yes, it is gluten free.</p>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span>Is it dairy free?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Yes, it is dairy free.</p>
          </div>
        </div>
      </div>

      <div class="faq-category" id="orders">
        <h2>ORDERS & SHIPPING</h2>

        <div class="faq-item">
          <div class="faq-question">
            <span>How long does shipping take?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Shipping usually takes 3-5 business days.</p>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            <span>Can I return products?</span>
            <span>+</span>
          </div>
          <div class="faq-answer">
            <p>Yes within 30 days.</p>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
.custom-faqs {
  background: #64604d;
  padding: 80px 20px;
}

.custom-faqs__wrapper {
  background: #f8f6f2;
  display: flex;
  gap: 80px;
  padding: 60px;
  max-width: 1300px;
  margin: auto;
}

.custom-faqs__sidebar {
  width: 240px;
  position: sticky;
  top: 120px;
  height: fit-content;
}

.custom-faqs__sidebar ul {
  margin: 0;
  padding: 0;
  list-style: none;
}

.custom-faqs__sidebar li {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  cursor: pointer;
  border-bottom: 1px solid rgba(0,0,0,.1);
  color: #8b8777;
  transition: .3s ease;
  font-size: 13px;
  letter-spacing: 1px;
}

.custom-faqs__sidebar li svg {
  width: 18px;
  height: 18px;
  opacity: 0;
  transform: translateX(-5px);
  transition: .3s ease;
}

.custom-faqs__sidebar li.active {
  color: #000;
}

.custom-faqs__sidebar li.active svg {
  opacity: 1;
  transform: translateX(0);
}

.custom-faqs__content {
  flex: 1;
}

.faq-category {
  margin-bottom: 80px;
  scroll-margin-top: 120px;
}

.faq-category h2 {
  font-size: 14px;
  letter-spacing: 2px;
  margin-bottom: 30px;
  color: #9c7d52;
}

.faq-item {
  border-bottom: 1px solid rgba(0,0,0,.1);
}

.faq-question {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  cursor: pointer;
  padding: 22px 0;
  font-size: 15px;
}

.faq-question span:last-child {
  transition: .3s ease;
}

.faq-item.active .faq-question span:last-child {
  transform: rotate(45deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height .5s ease, padding .5s ease;
  padding: 0;
}

.faq-answer p {
  margin: 0;
  padding-bottom: 24px;
  color: #555;
  line-height: 1.8;
  font-size: 14px;
}

.faq-item.active .faq-answer {
  max-height: 300px;
}

.custom-faqs__mobile-dropdown {
  display: none;
}

html {
  scroll-behavior: smooth;
}

@media(max-width: 989px){

  .custom-faqs__wrapper {
    flex-direction: column;
    padding: 30px 20px;
    gap: 40px;
  }

  .custom-faqs__sidebar {
    display: none;
  }

  .custom-faqs__mobile-dropdown {
    display: block;
  }

  .custom-faqs__mobile-dropdown select {
    width: 100%;
    height: 52px;
    border: 1px solid rgba(0,0,0,.1);
    background: transparent;
    padding: 0 16px;
    font-size: 13px;
    letter-spacing: 1px;
  }

  .faq-category {
    display: none;
    margin-bottom: 0;
  }

  .faq-category.active-mobile {
    display: block;
  }

  .faq-question {
    padding: 18px 0;
    font-size: 14px;
  }

}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const sidebarItems = document.querySelectorAll(".custom-faqs__sidebar li");
  const categories = document.querySelectorAll(".faq-category");

  sidebarItems.forEach(item => {
    item.addEventListener("click", () => {

      const target = item.dataset.target;
      const targetEl = document.getElementById(target);

      window.scrollTo({
        top: targetEl.offsetTop - 100,
        behavior: "smooth"
      });

    });
  });

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(entry => {

      if(entry.isIntersecting){

        const id = entry.target.getAttribute("id");

        sidebarItems.forEach(item => {
          item.classList.remove("active");

          if(item.dataset.target === id){
            item.classList.add("active");
          }
        });

      }

    });

  }, {
    threshold: 0.3
  });

  categories.forEach(section => {
    observer.observe(section);
  });

  const faqItems = document.querySelectorAll(".faq-item");

  faqItems.forEach(item => {

    const question = item.querySelector(".faq-question");

    question.addEventListener("click", () => {

      const isActive = item.classList.contains("active");

      faqItems.forEach(i => {
        i.classList.remove("active");
      });

      if(!isActive){
        item.classList.add("active");
      }

    });

  });

  const select = document.getElementById("faqCategorySelect");

  function mobileCategoryShow(value){

    categories.forEach(cat => {
      cat.classList.remove("active-mobile");
    });

    document.getElementById(value).classList.add("active-mobile");

  }

  if(window.innerWidth < 990){
    mobileCategoryShow(select.value);
  }

  select.addEventListener("change", function(){
    mobileCategoryShow(this.value);
  });

});
</script>



{% schema %}
{
  "name": "FAQs",
  "tag": "section",
  "settings": [
  ],

  "presets": [
    {
      "name": "FAQs"
    }
  ]
}
{% endschema %}