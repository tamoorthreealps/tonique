{{ 'css--video-reviews.css' | asset_url | stylesheet_tag }}

<div
  class="vr-section vr-section--mobile-{{ section.settings.mobile_layout }}"
  id="VideoReviews-{{ section.id }}"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="vr-inner">
    {%- comment -%} ── Heading ── {%- endcomment -%}
    <div class="vr-heading-block">
      {%- assign mobile_heading = section.settings.mobile_heading | default: section.settings.heading -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="vr-heading">
          <span class="vr-heading--desktop">
            {{ section.settings.heading }}
          </span>

          <span class="vr-heading--mobile">
            {{ mobile_heading }}
          </span>
        </h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="vr-subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Cards ── {%- endcomment -%}
    <div class="vr-cards splide js-vr-slider">
  <div class="splide__track">
    <div class="splide__list">
      {%- for block in section.blocks -%}
        {%- assign has_video = false -%}
        {%- if block.settings.video != blank -%}
          {%- assign has_video = true -%}
        {%- endif -%}

        <div class="vr-card splide__slide" {{ block.shopify_attributes }}>
          {%- comment -%} Video wrapper — click opens popup {%- endcomment -%}
          <div
            class="vr-card__video-wrap"
            data-vr-card="{{ forloop.index }}"
            data-vr-section="{{ section.id }}"
            role="button"
            tabindex="0"
            aria-label="Play video{% if block.settings.handle != blank %} by {{ block.settings.handle }}{% endif %}"
          >
            {%- comment -%} Background autoplay muted video {%- endcomment -%}
            {%- if has_video -%}
              <video
                class="vr-card__bg-video"
                autoplay
                muted
                loop
                playsinline
                aria-hidden="true"
                {%- if block.settings.poster != blank %}
                  poster="{{ block.settings.poster | image_url: width: 578 }}"
                {%- endif %}
              >
                {%- for source in block.settings.video.sources -%}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {%- endfor -%}
              </video>
            {%- elsif block.settings.poster != blank -%}
              {%- comment -%} No video — show poster only {%- endcomment -%}
              {{-
                block.settings.poster
                | image_url: width: 578
                | image_tag: loading: 'lazy', alt: block.settings.handle, class: 'vr-card__poster'
              -}}
            {%- endif -%}

            {%- comment -%} Badge pill {%- endcomment -%}
            {%- if block.settings.badge_label != blank -%}
              <span class="vr-card__badge">{{ block.settings.badge_label }}</span>
            {%- endif -%}

            {%- comment -%} Play button {%- endcomment -%}
            <button
              class="vr-card__play"
              type="button"
              aria-label="Play video{% if block.settings.handle != blank %} by {{ block.settings.handle }}{% endif %}"
              data-vr-play="{{ forloop.index }}"
              data-vr-section="{{ section.id }}"
            >
              <svg width="27" height="30" viewBox="0 0 27 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.4903 0.12988C0.823694 -0.245122 0 0.236589 0 1.00143V28.4389C0 29.2037 0.823621 29.6854 1.49022 29.3105L25.8791 15.5931C26.5587 15.2108 26.5588 14.2323 25.8791 13.85L1.4903 0.12988Z" fill="#F4F1E3"/>
              </svg>
            </button>

            {%- comment -%} Store video sources as JSON for popup JS {%- endcomment -%}
            {%- if has_video -%}
              <script type="application/json" class="vr-card__sources">
                [
                  {%- for source in block.settings.video.sources -%}
                    {"url": {{ source.url | json }}, "type": {{ source.mime_type | json }}}
                    {%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ]
              </script>
            {%- endif -%}
          </div>

          {%- comment -%} User info {%- endcomment -%}
          <div class="vr-card__info">
            {%- if block.settings.handle != blank -%}
              <p class="vr-card__handle">{{ block.settings.handle }}</p>
            {%- endif -%}
            {%- if block.settings.role != blank -%}
              <p class="vr-card__role">{{ block.settings.role }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
    </div>
    </div>

    {%- comment -%} ── Disclaimer ── {%- endcomment -%}
    {%- if section.settings.disclaimer != blank -%}
      <div class="vr-note">
        <div class="vr-note__line" aria-hidden="true"></div>
        <p class="vr-note__text">{{ section.settings.disclaimer }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Popup modal (one per section, reused for all cards) ── {%- endcomment -%}
<div
  class="vr-modal"
  id="vr-modal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Video player"
  hidden
>
  <div class="vr-modal__inner">
    <video
      class="vr-modal__video"
      id="vr-modal-video-{{ section.id }}"
      controls
      playsinline
    ></video>

    <button
      class="vr-modal__close"
      type="button"
      aria-label="Close video"
      data-vr-close="{{ section.id }}"
    >
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<script>
  (function () {
    var sid = '{{ section.id }}';
    var modal = document.getElementById('vr-modal-' + sid);
    var vid = document.getElementById('vr-modal-video-' + sid);

    if (!modal || !vid) return;

    function openModal(sources) {
      // Clear previous sources
      vid.innerHTML = '';
      sources.forEach(function (s) {
        var src = document.createElement('source');
        src.src = s.url;
        src.type = s.type;
        vid.appendChild(src);
      });

      vid.load();
      modal.removeAttribute('hidden');
      requestAnimationFrame(function () {
        modal.classList.add('is-open');
      });
      document.body.style.overflow = 'hidden';
      vid.play().catch(function () {});
    }

    function closeModal() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
      vid.pause();
      vid.currentTime = 0;
      setTimeout(function () {
        modal.setAttribute('hidden', '');
        vid.innerHTML = '';
      }, 300);
    }

    // Play button click
    document.querySelectorAll('.vr-card__play[data-vr-section="' + sid + '"]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var cardIdx = this.dataset.vrPlay;
        var wrap = document.querySelector(
          '.vr-card__video-wrap[data-vr-card="' + cardIdx + '"][data-vr-section="' + sid + '"]'
        );
        var srcEl = wrap && wrap.querySelector('.vr-card__sources');
        if (!srcEl) return;
        try {
          var sources = JSON.parse(srcEl.textContent);
          openModal(sources);
        } catch (err) {
          console.error('[vr] source parse error', err);
        }
      });
    });

    // Card wrapper click (accessibility — keyboard Enter/Space)
    document.querySelectorAll('.vr-card__video-wrap[data-vr-section="' + sid + '"]').forEach(function (wrap) {
      wrap.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          var playBtn = this.querySelector('.vr-card__play');
          if (playBtn) playBtn.click();
        }
      });
    });

    // Close button
    var closeBtn = modal.querySelector('[data-vr-close]');
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    // Click backdrop to close
    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    // Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  })();
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  if(window.innerWidth > 767) return;
  document.querySelectorAll('.vr-section--mobile-slider .js-vr-slider').forEach(function(slider){
    new Splide(slider, {
      type: 'loop',
      perPage: 2,
      gap: '0px',
      arrows: false,
      pagination: false,
      autoplay: true,
      interval: 4000,
      pauseOnHover: false,
      pauseOnFocus: false,
      drag: true,
      snap: true,
      speed: 1000,
    }).mount();
  });
});
</script>
{% schema %}
{
  "name": "Video Reviews",
  "class": "section-video-reviews",
  "settings": [
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "default": "cards",
      "options": [
        {
          "value": "cards",
          "label": "Cards Grid"
        },
        {
          "value": "slider",
          "label": "Splide Slider"
        }
      ]
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See why they keep one in their bag"
    },
    {
      "type": "text",
      "id": "mobile_heading",
      "label": "Mobile heading"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "From Pilates instructors to busy moms, see how Tonique fits into the moments that matter."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "*Testimonials featured in videos or other promotional materials may include individuals who have received compensation, free product, or other incentives."
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video (MP4)"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Thumbnail / poster image",
          "info": "Shown before the video loads. Also used as a fallback if no video is uploaded."
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge label",
          "default": "CLEAN LABEL",
          "info": "Short pill badge shown on the card (e.g. CLEAN LABEL, DAILY USE, TASTE)"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Username / handle",
          "default": "@mayarstudio"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / description",
          "default": "Pilates instructor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Reviews",
      "blocks": [
        {
          "type": "video_card",
          "settings": {
            "badge_label": "CLEAN LABEL",
            "handle": "@mayarstudio",
            "role": "Pilates instructor"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "badge_label": "DAILY USE",
            "handle": "@mayarstudio",
            "role": "Strength coach"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "badge_label": "TASTE",
            "handle": "Jess T.",
            "role": "Wellness creator"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "badge_label": "FOR YOU",
            "handle": "@mayarstudio",
            "role": "Working mom"
          }
        }
      ]
    }
  ]
}
{% endschema %}
