        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "KSM-66® Ashwagandha",
            "amount": "600mg",
            "badge_label": "ADAPTOGEN",
            "description": "The most clinically studied ashwagandha extract — supports stress resilience and recovery."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Hyaluronic Acid",
            "amount": "120mg",
