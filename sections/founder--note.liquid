{{ 'css--founder-note.css' | asset_url | stylesheet_tag }}

<section
  class="fn-section"
  id="FounderNote-{{ section.id }}"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="fn-inner">

    {%- if section.settings.image != blank -%}
      <div class="fn-media">
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            alt: section.settings.heading,
            class: 'fn-media__img'
        }}
      </div>
    {%- endif -%}

    <div class="fn-content">

      {%- if section.settings.heading != blank -%}
        <h2 class="fn-heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="fn-text rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      <div class="fn-footer">

        <div class="fn-meta">
          {%- if section.settings.name != blank -%}
            <p class="fn-name">
              — {{ section.settings.name }}
            </p>
          {%- endif -%}

          {%- if section.settings.role != blank -%}
            <p class="fn-role">
              {{ section.settings.role }}
            </p>
          {%- endif -%}
        </div>

        {%- if section.settings.signature != blank -%}
          <div class="fn-signature">
            {{
              section.settings.signature
              | image_url: width: 300
              | image_tag:
                loading: 'lazy',
                alt: section.settings.name,
                class: 'fn-signature__img'
            }}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Note",
  "class": "section-founder-note",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Top image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT BY THE CUSTOMER, FOR THE CUSTOMER."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "NIMMI ROCHE"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role",
      "default": "FOUNDER, TONIQUE"
    },
    {
      "type": "image_picker",
      "id": "signature",
      "label": "Signature image"
    },

    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 120
    },

    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Founder Note"
    }
  ]
}
{% endschema %}