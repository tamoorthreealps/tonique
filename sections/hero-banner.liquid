{{ 'css--hero-banner.css' | asset_url | stylesheet_tag }}

<section class="hb-section" id="HeroBanner-{{ section.id }}">
  <div class="hb-inner">

    {%- comment -%} Decorative vector – desktop only, top-right {%- endcomment -%}
    {%- if section.settings.decorative_image != blank -%}
      <div class="hb-vector" aria-hidden="true">
        {{
          section.settings.decorative_image
          | image_url: width: 1031
          | image_tag: loading: 'eager', alt: ''
        }}
      </div>
    {%- endif -%}

    {%- comment -%} Media column (product image + floating stat badges) {%- endcomment -%}
    <div class="hb-media">
      <div class="hb-media__img-wrap">
        {%- if section.settings.product_image != blank -%}
          {{
            section.settings.product_image
            | image_url: width: 600
            | image_tag:
              loading: 'eager',
              class: 'hb-media__img',
              widths: '278, 400, 556, 600',
              sizes: '(min-width: 767px) 278px, 240px',
              alt: section.settings.product_image.alt | escape
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg hb-media__img' }}
        {%- endif -%}
      </div>

      {%- comment -%} Stat badges {%- endcomment -%}
      <div class="hb-badges" aria-hidden="true">
        {%- assign badge_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat_badge' -%}
            {%- assign badge_count = badge_count | plus: 1 -%}
            <div
              class="hb-badge hb-badge--circle hb-badge--{{ badge_count }}"
              {{ block.shopify_attributes }}
            >
              <span class="hb-badge__value">{{ block.settings.value }}</span>
              <span class="hb-badge__label">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Content column (heading + subtext + CTA) {%- endcomment -%}
    <div class="hb-content">
      {%- if section.settings.heading != blank -%}
        <h1 class="hb-content__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="hb-content__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="hb-content__cta"
        >
          {{- section.settings.cta_label -}}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty + Protein\nin one clean pouch",
      "info": "Use \\n for a line break"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "15g of complete protein. All natural. Zero sugar. Collagen + whey. Beauty nutrients. Adaptogens. One pouch. Done."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "image_picker",
      "id": "decorative_image",
      "label": "Decorative vector / background image",
      "info": "Shown at top-right on desktop only. Upload the decorative SVG/PNG."
    }
  ],
  "blocks": [
    {
      "type": "stat_badge",
      "name": "Stat Badge",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value (large text)",
          "default": "15g"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (small text)",
          "default": "PROTEIN"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "stat_badge",
          "settings": { "value": "15g", "label": "PROTEIN" }
        },
        {
          "type": "stat_badge",
          "settings": { "value": "0g", "label": "Sugar" }
        },
        {
          "type": "stat_badge",
          "settings": { "value": "1oz", "label": "POUCH" }
        },
        {
          "type": "stat_badge",
          "settings": { "value": "70", "label": "Calories" }
        }
      ]
    }
  ]
}
{% endschema %}
